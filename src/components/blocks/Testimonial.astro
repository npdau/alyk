---
/**
 * Testimonial Block
 *
 * Single featured quote with attribution.
 */
import Section from '@/components/core/Section.astro';

interface Props {
  quote: string;
  name: string;
  location?: string;
  background?: 'default' | 'muted';
}

const { quote, name, location, background = 'default' } = Astro.props;
---

<Section spacing="lg" background={background}>
  <div class="mx-auto max-w-3xl text-center">
    <svg class="mx-auto mb-6 h-8 w-8 text-stone-300" fill="currentColor" viewBox="0 0 24 24">
      <path
        d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
      ></path>
    </svg>
    <blockquote
      class="text-foreground text-lg leading-relaxed font-normal sm:text-xl"
      style="font-style: italic; line-height: 1.6;"
    >
      &ldquo;{quote}&rdquo;
    </blockquote>
    <p class="text-foreground mt-6 text-sm font-medium">
      {name}
      {location && <span class="text-muted-foreground">, {location}</span>}
    </p>
  </div>
</Section>
