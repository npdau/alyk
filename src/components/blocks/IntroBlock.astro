---
/**
 * IntroBlock
 *
 * Short value proposition with heading, body, and inline link.
 */
import Section from '@/components/core/Section.astro';

interface Props {
  heading: string;
  body: string | string[];
  link?: { text: string; href: string };
  /** Editorial eyebrow above the heading. */
  eyebrow?: string;
  /** Background variant */
  background?: 'default' | 'muted';
  /** Centered text alignment */
  align?: 'left' | 'center';
  /** Max width of the inner column */
  maxWidth?: 'sm' | 'md' | 'lg';
}

const {
  heading,
  body,
  link,
  eyebrow,
  background = 'muted',
  align = 'left',
  maxWidth = 'sm',
} = Astro.props;

const paragraphs = Array.isArray(body) ? body : [body];

const widthStyles = {
  sm: 'max-w-2xl',
  md: 'max-w-3xl',
  lg: 'max-w-4xl',
};
---

<Section spacing="lg" background={background}>
  <div class:list={['mx-auto', widthStyles[maxWidth], align === 'center' && 'text-center']}>
    {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      {heading}
    </h2>
    <div class="mt-6 space-y-5 text-base leading-relaxed sm:text-lg" style="line-height: 1.55;">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
    {
      link && (
        <p class="mt-8">
          <a
            href={link.href}
            class="text-foreground hover:border-navy-700 hover:text-navy-700 border-b border-stone-300 text-sm font-medium no-underline transition-colors"
          >
            {link.text} &rarr;
          </a>
        </p>
      )
    }
  </div>
</Section>
