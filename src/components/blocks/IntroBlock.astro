---
/**
 * IntroBlock
 *
 * Short value proposition with heading, body, and inline link.
 */
import Section from '@/components/core/Section.astro';

interface Props {
  heading: string;
  body?: string | string[];
  /** Optional dash-prefixed list rendered below the body. */
  bullets?: string[];
  link?: { text: string; href: string };
  /** Editorial eyebrow above the heading. */
  eyebrow?: string;
  /** Background variant */
  background?: 'default' | 'muted';
  /** Centered text alignment */
  align?: 'left' | 'center';
  /** Max width of the inner column */
  maxWidth?: 'sm' | 'md' | 'lg';
}

const {
  heading,
  body,
  bullets,
  link,
  eyebrow,
  background = 'muted',
  align = 'left',
  maxWidth = 'sm',
} = Astro.props;

const paragraphs = body ? (Array.isArray(body) ? body : [body]) : [];

const widthStyles = {
  sm: 'max-w-2xl',
  md: 'max-w-3xl',
  lg: 'max-w-4xl',
};
---

<Section spacing="lg" background={background}>
  <div class:list={['reveal mx-auto', widthStyles[maxWidth], align === 'center' && 'text-center']}>
    {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      {heading}
    </h2>
    {
      paragraphs.length > 0 && (
        <div class="mt-6 space-y-5 text-base leading-relaxed sm:text-lg" style="line-height: 1.55;">
          {paragraphs.map((p) => (
            <p>{p}</p>
          ))}
        </div>
      )
    }
    {
      bullets && bullets.length > 0 && (
        <ul
          class:list={[
            'space-y-3 text-base leading-relaxed sm:text-lg',
            paragraphs.length > 0 ? 'mt-6' : 'mt-6',
          ]}
          style="line-height: 1.55;"
        >
          {bullets.map((item) => (
            <li class="flex gap-3">
              <span class="text-muted-foreground select-none" aria-hidden="true">
                -
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      )
    }
    {
      link && (
        <p class="mt-8">
          <a
            href={link.href}
            class="text-foreground hover:border-navy-700 hover:text-navy-700 border-b border-stone-300 text-sm font-medium no-underline transition-colors"
          >
            {link.text} &rarr;
          </a>
        </p>
      )
    }
  </div>
</Section>
