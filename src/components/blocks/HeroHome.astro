---
/**
 * HeroHome Block
 *
 * Full-bleed hero with background image. Headline/subheadline/CTA are
 * optional - omit them all for a plain image hero (used on project
 * detail pages).
 */
import { Image } from 'astro:assets';
import Button from '@/components/core/Button.astro';

interface Props {
  headline?: string;
  subheadline?: string;
  cta?: { text: string; href: string };
  image: { src: any; alt: string };
  /**
   * Hero height. Defaults to `default` (90vh) for landing-style heroes.
   * Use `short` (60vh) for project detail pages where the hero is a
   * plain image only and shouldn't push the page content too far down.
   */
  height?: 'default' | 'short';
  /** Override image positioning classes (object-position, scale, etc.) */
  imageClass?: string;
  /** Overlay gradient strength - use 'light' for naturally dark images, 'strong' for busy/bright images */
  overlay?: 'default' | 'light' | 'strong';
}

const {
  headline,
  subheadline,
  cta,
  image,
  height = 'default',
  imageClass,
  overlay = 'default',
} = Astro.props;

// When no headline is provided, treat as a plain image hero - no full
// navy overlay, just a soft top gradient so the nav stays legible.
const isPlain = !headline;

const heightStyles = {
  default: 'min-h-[80vh] md:min-h-[90vh]',
  short: 'min-h-[50vh] md:min-h-[70vh]',
};
---

<section class:list={['bg-navy-900 relative flex items-end overflow-hidden', heightStyles[height]]}>
  <Image
    src={image.src}
    alt={image.alt}
    class:list={[
      'absolute inset-0 h-full w-full object-cover',
      imageClass || 'scale-125 object-[center_5%] md:scale-100 md:object-center',
    ]}
    widths={[800, 1200, 1800, 2400]}
    sizes="100vw"
    loading="eager"
    inferSize
  />

  {
    isPlain ? (
      <div
        class="absolute inset-x-0 top-0 h-44"
        style="background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);"
      />
    ) : (
      <div
        class="hero-overlay absolute inset-0"
        style={
          overlay === 'light'
            ? 'background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.05) 30%, rgba(0,0,0,0.6) 100%);'
            : overlay === 'strong'
              ? 'background: linear-gradient(180deg, rgba(0,0,0,0.6) 0%, transparent 25%), linear-gradient(to top right, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.4) 35%, transparent 65%);'
              : 'background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.05) 30%, rgba(0,0,0,0.7) 100%);'
        }
      />
    )
  }

  <!-- Frame lines — top line always visible; side lines + chevron hidden on mobile -->
  <div class="pointer-events-none absolute inset-0 z-20" aria-hidden="true">
    <div
      class="absolute top-0 bottom-0 left-6 hidden w-px bg-white/25 lg:left-10 lg:block xl:left-20"
    >
    </div>
    <div
      class="absolute top-0 right-6 bottom-0 hidden w-px bg-white/25 lg:right-10 lg:block xl:right-20"
    >
    </div>
    <div class="absolute top-24 right-0 left-0 h-px bg-white/25"></div>
    <div
      class="absolute right-0 bottom-6 left-0 hidden h-px bg-white/25 lg:bottom-10 lg:block xl:bottom-20"
    >
    </div>
  </div>

  {
    headline && (
      <div class="relative z-10 w-full pb-44 md:pb-56">
        <div class="mx-auto max-w-7xl px-6 sm:px-8 md:px-10 lg:px-16 xl:px-28 2xl:px-8">
          <h1
            class="max-w-2xl text-4xl font-semibold tracking-tight text-stone-50 sm:text-5xl lg:text-6xl"
            style="line-height: 1.05; letter-spacing: -0.025em;"
          >
            {headline}
          </h1>
          {subheadline && (
            <p class="mt-6 max-w-lg text-base text-balance text-stone-50 sm:text-lg">
              {subheadline}
            </p>
          )}
          {cta && (
            <div class="mt-8">
              <Button href={cta.href} variant="white" size="lg" pill arrow>
                {cta.text}
              </Button>
            </div>
          )}
        </div>
      </div>
    )
  }
</section>

<style>
  @media (min-width: 768px) {
    .hero-overlay {
      mask-image: linear-gradient(to bottom right, black 55%, transparent 95%);
      -webkit-mask-image: linear-gradient(to bottom right, black 55%, transparent 95%);
    }
  }
</style>
