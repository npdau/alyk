---
/**
 * TestimonialsGrid Block
 *
 * Three-column quote grid. Shows first ~5 lines of each quote with a
 * "Read more" link to the project page for longer testimonials.
 */
import Section from '@/components/core/Section.astro';

interface Testimonial {
  quote: string;
  name: string;
  location?: string;
  /** When true, the quote is rendered as a muted placeholder card. */
  placeholder?: boolean;
  /** Link to the project page where the full testimonial lives. */
  projectHref?: string;
}

interface Props {
  heading: string;
  eyebrow?: string;
  leadIn?: string;
  testimonials: Testimonial[];
  background?: 'default' | 'muted';
}

const { heading, eyebrow, leadIn, testimonials, background = 'default' } = Astro.props;
---

<Section spacing="lg" background={background}>
  <div class="mx-auto mb-12 max-w-2xl text-center">
    {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      {heading}
    </h2>
    {leadIn && <p class="mt-4 text-base leading-relaxed">{leadIn}</p>}
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
    {
      testimonials.map((t) =>
        t.placeholder ? (
          <figure class="border-border bg-card flex h-full flex-col rounded-lg border border-dashed p-8">
            <blockquote
              class="text-muted-foreground flex-1 text-base leading-relaxed"
              style="line-height: 1.6;"
            >
              {t.quote}
            </blockquote>
            <figcaption class="text-muted-foreground mt-6 text-sm font-medium">
              {t.name}
              {t.location && <span>, {t.location}</span>}
            </figcaption>
          </figure>
        ) : (
          <figure class="border-border bg-card flex h-full flex-col rounded-lg border p-8 shadow-sm">
            <blockquote
              class="text-foreground line-clamp-5 flex-1 text-base leading-relaxed"
              style="font-style: italic; line-height: 1.6;"
            >
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <div class="mt-6 flex items-end justify-between gap-4">
              <figcaption class="text-foreground text-sm font-medium">
                <span class="block">{t.name}</span>
                {t.location && <span class="text-muted-foreground block">{t.location}</span>}
              </figcaption>
              {t.projectHref && (
                <a
                  href={t.projectHref}
                  class="text-foreground hover:border-navy-700 hover:text-navy-700 border-b border-stone-300 text-sm font-medium no-underline transition-colors"
                >
                  Read more &rarr;
                </a>
              )}
            </div>
          </figure>
        )
      )
    }
  </div>
</Section>
