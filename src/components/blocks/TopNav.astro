          ></path>
          <path
            d="M572.92,198.04l19.87,36.81h-5.88l-4.1-7.78h-19.92l-4.14,7.78h-6l20.18-36.81ZM580.37,222.51l-7.51-14.21-7.54,14.21h15.06Z"
          ></path>
          <path
            d="M611.57,235.24c-5.75.02-11.71-1.6-15.83-4.2l2.95-4.26c3.78,2.27,8.61,3.54,13.12,3.51,4.94-.04,8.28-1.92,8.35-5.14.07-2.97-1.92-4.07-7.11-5.26l-4.67-1.07c-7.57-1.72-11.08-4.87-11.1-10.08-.03-5.75,5.75-9.66,13.55-9.71,5.14-.03,10.14,1.53,13.8,3.79l-2.78,4.24c-3.12-1.91-6.7-3.11-10.52-3.09-4.87.05-8.25,1.78-8.22,4.92.03,2.73,2.22,4.09,6.86,5.14l4.99,1.12c7.52,1.7,10.82,4.57,10.84,9.97.03,6-5.78,10.08-14.23,10.11Z"
          ></path>
          <polygon
            points="642.27 204.44 629.91 204.44 629.88 199.45 660.01 199.45 660.01 204.44 647.68 204.44 647.68 234.82 642.27 234.82 642.27 204.44"
          ></polygon>
        </g>
      </svg>
    </a>

    <!-- Centered frosted glass nav pill -->
    <nav
      class="absolute left-1/2 hidden h-13 -translate-x-1/2 items-center gap-1 rounded-full bg-white/10 px-3 ring-1 ring-stone-400/50 backdrop-blur-xl lg:flex"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'border-0 px-5 py-2.5 text-sm tracking-[0.01em] text-white no-underline transition-opacity',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'font-semibold opacity-100'
                : 'font-medium opacity-75 hover:opacity-100',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- CTA button -->
    <div class="hidden lg:block">
      <Button href="/contact/" variant="white" size="lg" pill arrow class="btn-nav-cta">
        Begin a project
      </Button>
    </div>

    <!-- Mobile menu button -->
    <button
      type="button"
      class:list={[
        '-mr-2 p-2 transition-colors duration-500 ease-[cubic-bezier(0.22,0.61,0.36,1)] lg:hidden',
        transparent ? 'text-stone-50' : 'text-foreground',
      ]}
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="mobile-menu-button"
    >
      <span class="hamburger" aria-hidden="true">
        <span class="hb-line"></span>
        <span class="hb-line"></span>
        <span class="hb-line"></span>
      </span>
    </button>
  </div>

  <!-- Mobile menu - sits behind the logo bar, anchored to top:0 so the
       whole navy area collapses as a single block back to the page top. -->
  <nav
    class="bg-primary/85 mobile-menu absolute inset-x-0 top-0 grid grid-rows-[0fr] backdrop-blur-2xl backdrop-saturate-150 transition-[grid-template-rows] duration-500 ease-[cubic-bezier(0.22,0.61,0.36,1)] lg:hidden"
    id="mobile-menu"
  >
    <div class="min-h-0 overflow-hidden">
      <div class="mx-auto max-w-7xl px-5 pt-24 pb-10 sm:px-8">
        <!-- Primary nav - large editorial type with index numbers -->
        <ul>
          {
            navItems.map((item, i) => (
              <li class="menu-item border-b border-white/10" style={`--i: ${i}`}>
                <a
                  href={item.href}
                  class:list={[
                    'flex items-baseline justify-between border-0 py-4 no-underline transition-opacity',
                    currentPath === item.href ||
                    (item.href !== '/' && currentPath.startsWith(item.href))
                      ? 'opacity-100'
                      : 'opacity-90 hover:opacity-100',
                  ]}
                >
                  <span class="font-heading text-2xl font-light tracking-tight text-white sm:text-3xl">
                    {item.label}
                  </span>
                  <span class="text-[0.6875rem] font-medium tracking-[0.2em] text-white/40 tabular-nums">
                    0{i + 1}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Direct contact -->
        <div class="menu-item mt-8" style="--i: 5">
          <p class="mb-3 text-[0.6875rem] font-medium tracking-[0.18em] text-white/40 uppercase">
            Call
          </p>
          <ul class="space-y-2">
            <li>
              <a
                href="tel:0401023458"
                class="border-0 text-base text-white no-underline transition-opacity hover:opacity-70"
              >
                <span class="text-white/80">Aaron</span>
                <span class="ml-3 tabular-nums">0401 023 458</span>
              </a>
            </li>
            <li>
              <a
                href="tel:0432363124"
                class="border-0 text-base text-white no-underline transition-opacity hover:opacity-70"
              >
                <span class="text-white/80">Yarran</span>
                <span class="ml-3 tabular-nums">0432 363 124</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- CTA -->
        <div class="menu-item mt-8" style="--i: 6">
          <Button href="/contact/" variant="white" size="lg" pill arrow> Begin a project </Button>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  /* Long-short-long hamburger that morphs to an X */
  .hamburger {
    position: relative;
    display: block;
    width: 22px;
    height: 13px;
  }

  .hb-line {
    position: absolute;
    height: 1.5px;
    background-color: currentColor;
    border-radius: 1px;
    transform-origin: center;
    transition:
      transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1),
      top 0.3s cubic-bezier(0.22, 0.61, 0.36, 1) 0.1s,
      width 0.3s cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 0.2s ease;
  }

  .hb-line:nth-child(1) {
    top: 0;
    left: 0;
    width: 100%;
  }
  .hb-line:nth-child(2) {
    top: 6px;
    right: 0;
    width: 55%;
  }
  .hb-line:nth-child(3) {
    top: 12px;
    left: 0;
    width: 100%;
  }

  [aria-expanded='true'] .hb-line {
    transition:
      transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1) 0.15s,
      top 0.2s cubic-bezier(0.22, 0.61, 0.36, 1),
      width 0.2s cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 0.15s ease;
  }
  [aria-expanded='true'] .hb-line:nth-child(1) {
    top: 6px;
    transform: rotate(45deg);
  }
  [aria-expanded='true'] .hb-line:nth-child(2) {
    width: 0;
    opacity: 0;
  }
  [aria-expanded='true'] .hb-line:nth-child(3) {
    top: 6px;
    transform: rotate(-45deg);
  }

  /* Staggered reveal of menu rows */
  .menu-item {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.5s ease,
      transform 0.5s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .mobile-menu.is-open .menu-item {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--i, 0) * 60ms + 120ms);
  }
</style>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  let open = false;

  button?.addEventListener('click', () => {
    open = !open;
    button.setAttribute('aria-expanded', open ? 'true' : 'false');
    menu?.classList.toggle('grid-rows-[1fr]', open);
    menu?.classList.toggle('grid-rows-[0fr]', !open);
    menu?.classList.toggle('is-open', open);
    button?.classList.toggle('!text-white', open);
  });
</script>
