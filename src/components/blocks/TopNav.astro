---
/**
 * TopNav Block
 *
 * Site header with logo, navigation, and mobile menu.
 * Edit the navItems array and logo directly in this file.
 */
import Container from '@/components/core/Container.astro';
import Link from '@/components/core/Link.astro';
import Button from '@/components/core/Button.astro';

// Edit these navigation items for your site
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/blog/', label: 'Blog' },
  { href: '/contact/', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="bg-background/95 supports-[backdrop-filter]:bg-background/60 border-border sticky top-0 z-50 w-full border-b backdrop-blur"
>
  <Container>
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2 text-xl font-bold no-underline">
        <span>Your Logo</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden items-center gap-6 md:flex">
        {
          navItems.map((item) => (
            <Link href={item.href} variant="nav" active={currentPath === item.href}>
              {item.label}
            </Link>
          ))
        }
      </nav>

      <!-- Mobile menu button -->
      <Button
        variant="ghost"
        iconOnly
        class="text-muted-foreground md:hidden"
        aria-label="Toggle menu"
        id="mobile-menu-button"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </Button>
    </div>
  </Container>

  <!-- Mobile Navigation -->
  <nav class="border-border hidden border-t md:hidden" id="mobile-menu">
    <Container>
      <div class="space-y-3 py-4">
        {
          navItems.map((item) => (
            <Link href={item.href} variant="nav" active={currentPath === item.href} class="block">
              {item.label}
            </Link>
          ))
        }
      </div>
    </Container>
  </nav>
</header>

<script>
  // Simple mobile menu toggle
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
