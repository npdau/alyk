---
/**
 * ServicesSnapshot Block
 *
 * Intro text on the left, two service cards stacked on the right.
 */
import Section from '@/components/core/Section.astro';
import Card from '@/components/core/Card.astro';

interface ServiceCard {
  title: string;
  description: string;
  link: { text: string; href: string };
}

interface Props {
  heading: string;
  body: string;
  services: ServiceCard[];
}

const { heading, body, services } = Astro.props;
---

<Section spacing="lg" background="muted">
  <div class="grid items-start gap-12 md:grid-cols-2 md:gap-16 lg:gap-20">
    <div class="reveal">
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        {heading}
      </h2>
      <p class="mt-6 text-base leading-relaxed sm:text-lg" style="line-height: 1.55;">
        {body}
      </p>
    </div>

    <div class="flex flex-col gap-6">
      {
        services.map((service) => (
          <Card variant="outlined" padding="lg" class="reveal">
            <h3 class="text-xl font-semibold">{service.title}</h3>
            <p class="mt-3 text-sm leading-relaxed">{service.description}</p>
            <p class="mt-5">
              <a
                href={service.link.href}
                class="text-foreground hover:border-navy-700 hover:text-navy-700 border-b border-stone-300 text-sm font-medium no-underline transition-colors"
              >
                {service.link.text} &rarr;
              </a>
            </p>
          </Card>
        ))
      }
    </div>
  </div>
</Section>
