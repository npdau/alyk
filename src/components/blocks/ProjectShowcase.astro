---
/**
 * ProjectShowcase Block
 *
 * Featured project grid with auto-scrolling image carousels.
 */
import { Image } from 'astro:assets';
import { Swiper, SwiperWrapper, SwiperSlide, SwiperPagination } from 'astro-swiper';
import Section from '@/components/core/Section.astro';
import Badge from '@/components/core/Badge.astro';
import Button from '@/components/core/Button.astro';

interface ProjectImage {
  src: any;
  alt: string;
}

interface Project {
  title: string;
  tag: string;
  images: ProjectImage[];
  href: string;
}

interface Props {
  heading: string;
  description?: string;
  projects: Project[];
  cta?: { text: string; href: string };
}

const { heading, description, projects, cta } = Astro.props;
---

<Section spacing="lg">
  <div class="mb-10">
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      {heading}
    </h2>
    <div class="md:flex md:items-end md:justify-between md:gap-6">
      {description && <p class="mt-4 max-w-xl text-base leading-relaxed">{description}</p>}
      {
        cta && (
          <Button
            href={cta.href}
            variant="white"
            size="lg"
            pill
            class="hidden shrink-0 !pr-2 !pl-5 md:inline-flex"
          >
            {cta.text}
            <span class="bg-primary ml-2 inline-flex h-7 w-7 items-center justify-center rounded-full">
              <svg class="h-3 w-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </span>
          </Button>
        )
      }
    </div>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 sm:gap-8">
    {
      projects.map((project) => (
        <a
          href={project.href}
          class="project-card group relative block aspect-[4/3] overflow-hidden rounded-lg border-0 no-underline shadow-md"
        >
          <Swiper
            options={{
              loop: true,
              speed: 800,
              autoplay: {
                delay: 3500,
                disableOnInteraction: false,
              },
              pagination: {
                el: '.swiper-pagination',
                clickable: true,
              },
              astro: {
                useCustomElement: false,
                intersectionObserver: {
                  controlAutoplay: true,
                },
              },
            }}
            class="h-full w-full"
          >
            <SwiperWrapper>
              {project.images.map((img) => (
                <SwiperSlide>
                  <Image
                    src={img.src}
                    alt={img.alt}
                    class="h-full w-full object-cover"
                    widths={[400, 600, 800]}
                    sizes="(min-width: 640px) 50vw, 100vw"
                    inferSize
                  />
                </SwiperSlide>
              ))}
            </SwiperWrapper>
            <SwiperPagination />
          </Swiper>

          <div class="from-navy-900/70 pointer-events-none absolute inset-0 z-10 bg-gradient-to-t via-transparent to-transparent" />
          <div class="pointer-events-none absolute bottom-0 left-0 z-10 p-5">
            <p class="text-lg font-semibold text-stone-50">{project.title}</p>
            <Badge
              variant="secondary"
              size="sm"
              class="mt-2 bg-white/15 text-stone-50 backdrop-blur-sm"
            >
              {project.tag}
            </Badge>
          </div>
        </a>
      ))
    }
  </div>

  {
    cta && (
      <div class="mt-8 md:hidden">
        <Button href={cta.href} variant="white" size="lg" pill class="!pr-2 !pl-5">
          {cta.text}
          <span class="bg-primary ml-2 inline-flex h-7 w-7 items-center justify-center rounded-full">
            <svg class="h-3 w-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </span>
        </Button>
      </div>
    )
  }
</Section>

<style is:global>
  .project-card .swiper {
    height: 100%;
  }

  .project-card .swiper-slide {
    overflow: hidden;
  }

  .project-card .swiper-pagination {
    z-index: 20;
    bottom: 12px !important;
    display: flex;
    justify-content: center;
    gap: 6px;
  }

  .project-card .swiper-pagination-bullet {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.4);
    opacity: 1;
    transition: all 0.3s ease;
  }

  .project-card .swiper-pagination-bullet-active {
    width: 20px;
    background: rgba(255, 255, 255, 0.9);
  }
</style>
