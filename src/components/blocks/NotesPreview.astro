---
/**
 * NotesPreview Block
 *
 * Three-card grid of blog/notes teasers.
 */
import Section from '@/components/core/Section.astro';
import Card from '@/components/core/Card.astro';
import Button from '@/components/core/Button.astro';

interface NoteCard {
  title: string;
  excerpt: string;
  href: string;
}

interface Props {
  heading: string;
  description?: string;
  notes: NoteCard[];
  cta?: { text: string; href: string };
}

const { heading, description, notes, cta } = Astro.props;
---

<Section spacing="lg" background="muted">
  <div class="reveal mb-10">
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      {heading}
    </h2>
    {description && <p class="mt-3 max-w-xl text-base leading-relaxed">{description}</p>}
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      notes.map((note) => (
        <Card variant="outlined" padding="lg" class="reveal bg-card">
          <h3 class="text-base leading-snug font-semibold">{note.title}</h3>
          <p class="mt-2 text-sm leading-relaxed">{note.excerpt}</p>
          <p class="mt-4">
            <a
              href={note.href}
              class="text-foreground hover:border-navy-700 hover:text-navy-700 border-b border-stone-300 text-sm font-medium no-underline transition-colors"
            >
              Read &rarr;
            </a>
          </p>
        </Card>
      ))
    }
  </div>

  {
    cta && (
      <div class="mt-8">
        <Button href={cta.href} variant="outline" pill>
          {cta.text} &rarr;
        </Button>
      </div>
    )
  }
</Section>
