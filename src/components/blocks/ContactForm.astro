---
/**
 * ContactForm Block
 *
 * Two-column enquiry section: the form lives on the left in an elevated card
 * and direct contact details slot in on the right.
 *
 * Submissions are handled by Netlify Forms - no backend needed. Netlify
 * detects the form at deploy time via data-netlify="true" and routes
 * submissions to the site dashboard under Forms > contact.
 */
import Section from '@/components/core/Section.astro';
import Card from '@/components/core/Card.astro';
import Input from '@/components/core/Input.astro';
import Textarea from '@/components/core/Textarea.astro';
import Select from '@/components/core/Select.astro';
import Label from '@/components/core/Label.astro';
import Button from '@/components/core/Button.astro';

interface Props {
  /** Editorial eyebrow above the form heading. */
  eyebrow?: string;
  /** Form heading shown inside the card. */
  heading?: string;
  /** Netlify form name - appears in the dashboard under Forms. */
  formName?: string;
  /** Submit button label. */
  submitText?: string;
  /** Helper line shown directly under the submit button. */
  helper?: string;
  /** Success eyebrow shown after submission. */
  successEyebrow?: string;
  /** Success heading shown after submission. */
  successHeading?: string;
  /** Success body text shown after submission. */
  successBody?: string;
  /** Privacy note shown beneath the helper line. */
  privacyNote?: string;
  /** Privacy policy link target (opens inline in the privacy note). */
  privacyHref?: string;
  /** Background variant. */
  background?: 'default' | 'muted';
}

const {
  eyebrow = 'Enquiries',
  heading = 'Get in touch',
  formName = 'contact',
  submitText = 'Send',
  helper = 'We aim to reply within two business days.',
  successEyebrow = 'Sent',
  successHeading = "We've got your message",
  successBody = 'Our team will be in touch within two business days.',
  privacyNote = "We only use your details to reply to your enquiry. We don't share them, and we don't add you to any list.",
  privacyHref = '/privacy/',
  background = 'default',
} = Astro.props;

const projectTypes = [
  { value: 'new-build', label: 'New build' },
  { value: 'renovation', label: 'Renovation' },
  { value: 'not-sure', label: 'Not sure yet' },
];
---

<Section spacing="lg" background={background}>
  <div class="grid gap-12 lg:grid-cols-[minmax(0,7fr)_minmax(0,5fr)] lg:gap-16">
    <Card variant="elevated" padding="lg" class="reveal md:p-10">
      <div id="contact-form-wrap">
        {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
        <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
          {heading}
        </h2>

        <form
          name={formName}
          method="POST"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="mt-8 space-y-6"
          id="contact-form"
        >
          <input type="hidden" name="form-name" value={formName} />
          <p class="hidden">
            <label>
              Don't fill this out: <input name="bot-field" />
            </label>
          </p>

          <div class="grid gap-6 sm:grid-cols-2">
            <div class="space-y-2">
              <Label for="name" required>Your name</Label>
              <Input name="name" placeholder="Jane Smith" autocomplete="name" required />
            </div>
            <div class="space-y-2">
              <Label for="email" required>Email</Label>
              <Input
                name="email"
                type="email"
                placeholder="jane@example.com"
                autocomplete="email"
                required
              />
            </div>
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            <div class="space-y-2">
              <Label for="phone">Phone (optional)</Label>
              <Input name="phone" type="tel" placeholder="04xx xxx xxx" autocomplete="tel" />
            </div>
            <div class="space-y-2">
              <Label for="location" required>Project location</Label>
              <Input
                name="location"
                placeholder="Suburb or town"
                autocomplete="address-level2"
                required
              />
            </div>
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            <div class="space-y-2">
              <Label for="projectType" required>Project type</Label>
              <Select
                name="projectType"
                placeholder="Select one…"
                options={projectTypes}
                required
              />
            </div>
            <div class="space-y-2">
              <Label for="architect">Architect (if engaged)</Label>
              <Input name="architect" placeholder='Practice name, or "Not yet"' />
            </div>
          </div>

          <div class="space-y-2">
            <Label for="message" required>Message</Label>
            <Textarea
              name="message"
              placeholder="Tell us about the project and what you're hoping to achieve."
              rows={6}
              required
            />
          </div>

          <div class="flex flex-col gap-4 pt-2 sm:flex-row sm:items-center sm:justify-between">
            <Button type="submit" variant="primary" size="lg" pill arrow class="sm:w-auto">
              {submitText}
            </Button>
            {helper && <p class="text-muted-foreground text-sm">{helper}</p>}
          </div>

          {
            privacyNote && (
              <p class="text-muted-foreground border-border mt-6 border-t pt-6 text-xs leading-relaxed">
                {privacyNote}{' '}
                <a
                  href={privacyHref}
                  class="text-foreground hover:border-navy-700 hover:text-navy-700 border-b border-stone-300 no-underline transition-colors"
                >
                  Read our privacy policy
                </a>
                .
              </p>
            )
          }
        </form>
      </div>

      <div id="contact-success" class="hidden">
        <p class="eyebrow mb-3">{successEyebrow}</p>
        <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
          {successHeading}
        </h2>
        <p class="text-muted-foreground mt-6 text-base leading-relaxed text-balance sm:text-lg">
          {successBody} If it's urgent or you haven't heard back, please give us a call directly.
        </p>
      </div>
    </Card>

    <aside class="lg:flex lg:flex-col">
      <slot name="details" />
    </aside>
  </div>
</Section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const formWrap = document.getElementById('contact-form-wrap');
  const success = document.getElementById('contact-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Sending…';
    }

    try {
      const data = new FormData(form);
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as unknown as Record<string, string>).toString(),
      });

      formWrap?.classList.add('hidden');
      success?.classList.remove('hidden');
    } catch {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'Send';
      }
      alert('Something went wrong - please try again or call us directly.');
    }
  });
</script>
