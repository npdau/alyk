---
/**
 * ProjectInfo Block
 *
 * Bento layout: title/subtitle/description on the left balanced against
 * the details panel on the right, with a full-width collapsible
 * testimonial beneath.
 */
import Section from '@/components/core/Section.astro';
import Card from '@/components/core/Card.astro';

interface DetailItem {
  label: string;
  value: string;
}

interface Testimonial {
  quote: string[];
  name: string;
  location: string;
}

interface Props {
  title: string;
  subtitle?: string;
  description: string[];
  details: DetailItem[];
  testimonial?: Testimonial;
  background?: 'default' | 'muted';
}

const { title, subtitle, description, details, testimonial, background = 'default' } = Astro.props;
---

<Section spacing="lg" background={background}>
  <div
    class="testimonial-toggle grid items-center gap-10 md:grid-cols-[1fr_auto] md:gap-16 lg:gap-24"
    data-expanded="false"
  >
    <div class="min-w-0">
      <h1
        class="text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl"
        style="line-height: 1.1; letter-spacing: -0.02em;"
      >
        {title}
      </h1>

      {
        subtitle && (
          <p class="project-subtitle text-foreground mt-4 text-lg font-medium sm:text-xl md:max-w-3xl">
            {subtitle}
          </p>
        )
      }

      <div class="mt-8 space-y-4 text-sm leading-relaxed sm:text-base" style="line-height: 1.65;">
        {description.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <div class="md:w-72 lg:w-80">
      <Card variant="elevated" padding="lg">
        <dl class="space-y-4 text-sm">
          {
            details.map((item) => (
              <div>
                <dt class="text-foreground font-semibold">{item.label}</dt>
                <dd class="text-muted-foreground mt-0.5">{item.value}</dd>
              </div>
            ))
          }
        </dl>

        {
          testimonial && (
            <div id="testimonial" class="bg-muted/50 -mx-8 mt-5 -mb-8 rounded-b-lg px-8 py-5">
              <button
                type="button"
                class="testimonial-btn flex w-full cursor-pointer items-center justify-between gap-3 transition-colors"
                aria-expanded="false"
                aria-label="Expand client feedback"
              >
                <span class="text-foreground text-sm font-semibold">Client feedback</span>
                <span class="bg-card border-border inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border shadow-sm">
                  <svg
                    class="testimonial-icon text-foreground h-4 w-4 transition-transform duration-300"
                    viewBox="0 0 12 12"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <line x1="6" y1="2" x2="6" y2="10" />
                    <line x1="2" y1="6" x2="10" y2="6" />
                  </svg>
                </span>
              </button>
            </div>
          )
        }
      </Card>
    </div>
  </div>

  {
    testimonial && (
      <div
        class="testimonial-body overflow-hidden transition-[max-height] duration-500 ease-in-out"
        style="max-height: 0;"
      >
        <div class="px-1 pt-10 pb-4">
          <blockquote class="bg-card relative rounded-lg px-8 py-8 shadow-md sm:px-12 sm:py-10">
            <span
              class="pointer-events-none absolute top-4 left-6 font-serif text-[8rem] leading-none text-stone-200 select-none"
              aria-hidden="true"
            >
              &ldquo;
            </span>
            <div
              class="relative space-y-4 text-sm leading-relaxed sm:text-base"
              style="line-height: 1.75;"
            >
              {testimonial.quote.map((p) => (
                <p>{p}</p>
              ))}
            </div>
            <p class="text-foreground relative mt-6 text-sm font-semibold">
              {testimonial.name}
              <span class="text-muted-foreground font-normal">, {testimonial.location}</span>
            </p>
          </blockquote>
        </div>
      </div>
    )
  }
</Section>

<style>
  .project-subtitle {
    text-wrap: auto;
  }
</style>

<script>
  document.querySelectorAll('.testimonial-toggle').forEach((toggle) => {
    const btn = toggle.querySelector('.testimonial-btn');
    const body = (toggle.nextElementSibling as HTMLElement)?.classList.contains('testimonial-body')
      ? (toggle.nextElementSibling as HTMLElement)
      : null;
    const icon = toggle.querySelector('.testimonial-icon') as HTMLElement;

    if (!btn || !body) return;

    function expand() {
      body!.style.maxHeight = body!.scrollHeight + 'px';
      if (icon) icon.style.transform = 'rotate(45deg)';
      toggle.setAttribute('data-expanded', 'true');
      btn!.setAttribute('aria-expanded', 'true');
    }

    function collapse() {
      body!.style.maxHeight = '0px';
      if (icon) icon.style.transform = '';
      toggle.setAttribute('data-expanded', 'false');
      btn!.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', () => {
      const expanded = toggle.getAttribute('data-expanded') === 'true';
      if (expanded) {
        collapse();
      } else {
        expand();
      }
    });

    if (window.location.hash === '#testimonial') {
      expand();
      document
        .getElementById('testimonial')
        ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });
</script>
