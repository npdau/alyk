---
/**
 * PlaceStatement Block
 *
 * Place anchor with area description. When an image is provided,
 * renders a two-column layout (image left, text right) inspired
 * by AboutSummary. Falls back to centred text when no image is given.
 */
import { Image } from 'astro:assets';
import Section from '@/components/core/Section.astro';

interface Props {
  place: string;
  description: string | string[];
  /** Editorial eyebrow above the place heading. */
  eyebrow?: string;
  /** Background variant */
  background?: 'default' | 'muted';
  /** Optional image displayed beside the text. */
  image?: { src: any; alt: string };
}

const { place, description, eyebrow, background = 'default', image } = Astro.props;
const paragraphs = Array.isArray(description) ? description : [description];
---

<Section spacing="lg" background={background}>
  {
    image ? (
      <div class="grid items-center gap-12 md:grid-cols-[minmax(0,5fr)_minmax(0,7fr)] md:gap-16 lg:gap-20">
        <div class="reveal aspect-square overflow-hidden rounded-lg shadow-md">
          <Image
            src={image.src}
            alt={image.alt}
            width={640}
            height={640}
            class="h-full w-full object-cover object-center"
            loading="lazy"
          />
        </div>

        <div class="reveal flex flex-col justify-center">
          {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
          <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">{place}</h2>
          <div
            class="mt-6 space-y-5 text-base leading-relaxed sm:text-lg"
            style="line-height: 1.55;"
          >
            {paragraphs.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </div>
      </div>
    ) : (
      <div class="reveal mx-auto max-w-2xl text-center">
        {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
        <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">{place}</h2>
        <div class="mt-6 space-y-5 text-base leading-relaxed sm:text-lg" style="line-height: 1.55;">
          {paragraphs.map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </div>
    )
  }
</Section>
