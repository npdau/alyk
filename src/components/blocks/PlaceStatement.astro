---
/**
 * PlaceStatement Block
 *
 * Centered place anchor with area description.
 * Replaces the stats row from the mockup.
 */
import Section from '@/components/core/Section.astro';

interface Props {
  place: string;
  description: string | string[];
  /** Editorial eyebrow above the place heading. */
  eyebrow?: string;
  /** Background variant */
  background?: 'default' | 'muted';
}

const { place, description, eyebrow, background = 'default' } = Astro.props;
const paragraphs = Array.isArray(description) ? description : [description];
---

<Section spacing="lg" background={background}>
  <div class="mx-auto max-w-2xl text-center">
    {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      {place}
    </h2>
    <div class="mt-6 space-y-5 text-base leading-relaxed sm:text-lg" style="line-height: 1.55;">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</Section>
