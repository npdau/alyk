---
/**
 * ConsultationCTA Block
 *
 * Dark navy band with heading, body text, and CTA pill.
 */
import Section from '@/components/core/Section.astro';
import Button from '@/components/core/Button.astro';

interface Props {
  heading: string;
  body: string;
  cta: { text: string; href: string };
  /** Optional secondary action rendered alongside the primary pill. */
  secondaryCta?: { text: string; href: string };
}

const { heading, body, cta, secondaryCta } = Astro.props;
---

<Section spacing="lg" background="inverse">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-2xl font-semibold tracking-tight text-stone-50 sm:text-3xl">
      {heading}
    </h2>
    <p class="text-navy-300 mt-4 text-base leading-relaxed">
      {body}
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <Button href={cta.href} variant="white" size="lg" pill class="!pr-2 !pl-5">
        {cta.text}
        <span class="bg-primary ml-2 inline-flex h-7 w-7 items-center justify-center rounded-full">
          <svg class="h-3 w-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
            ></path>
          </svg>
        </span>
      </Button>
      {
        secondaryCta && (
          <Button href={secondaryCta.href} variant="ghost-light" size="lg" pill>
            {secondaryCta.text}
          </Button>
        )
      }
    </div>
  </div>
</Section>
