---
/**
 * ConsultationCTA Block
 *
 * Minimal CTA band - heading + button on a muted stone background.
 * Sits between page content and footer as a quiet prompt.
 */
import Section from '@/components/core/Section.astro';
import Button from '@/components/core/Button.astro';

interface Props {
  heading: string;
  body?: string;
  cta: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
  framed?: boolean;
  background?: 'default' | 'muted';
}

const { heading, cta, secondaryCta, background = 'muted' } = Astro.props;

const bgStyles = {
  default: 'bg-background',
  muted: 'bg-muted',
};
---

<section class:list={[bgStyles[background], 'py-16 md:py-20']}>
  <div
    class="reveal mx-auto flex max-w-5xl flex-col items-center justify-between gap-8 px-6 sm:px-8 md:flex-row md:gap-12"
  >
    <h2
      class="text-foreground text-center text-2xl font-semibold tracking-tight md:text-left md:text-3xl"
    >
      {heading}
    </h2>
    <div class="flex shrink-0 flex-wrap items-center gap-4">
      <Button
        href={cta.href}
        variant="white"
        size="lg"
        pill
        arrow
        class="btn-cta-pulse btn-nav-cta text-base"
      >
        {cta.text}
      </Button>
    </div>
  </div>
</section>
