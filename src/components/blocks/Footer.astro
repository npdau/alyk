---
/**
 * Footer Block
 *
 * ALYK Building footer — dark navy, minimal, editorial.
 */
import Container from '@/components/core/Container.astro';

const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/about/', label: 'About' },
  { href: '/services/', label: 'Services' },
  { href: '/projects/', label: 'Projects' },
  { href: '/contact/', label: 'Contact' },
];

const utilityLinks = [
  { href: '/faq/', label: 'FAQs' },
  { href: '/terms/', label: 'Terms & Conditions' },
  { href: '/privacy/', label: 'Privacy Policy' },
];
---

<footer class="bg-navy-900 text-stone-50">
  <Container size="xl">
    <div class="py-16 md:py-20">
      <div class="grid gap-12 md:grid-cols-12">
        <div class="md:col-span-5">
          <a
            href="/"
            class="border-0 text-sm font-medium tracking-[0.28em] text-stone-50 uppercase no-underline transition-opacity hover:opacity-80"
          >
            ALYK Building
          </a>
          <p class="text-navy-300 mt-4 max-w-sm text-sm leading-relaxed">
            Architectural homes and renovations on the Tweed Coast. Fingal Head to New Brighton.
          </p>
        </div>

        <div class="md:col-span-3">
          <p class="eyebrow text-navy-300 mb-4">Navigate</p>
          <ul class="space-y-2">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-navy-300 border-0 text-sm no-underline transition-colors hover:text-stone-50"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="md:col-span-2">
          <p class="eyebrow text-navy-300 mb-4">Legal</p>
          <ul class="space-y-2">
            {
              utilityLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-navy-300 border-0 text-sm no-underline transition-colors hover:text-stone-50"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="md:col-span-2">
          <p class="eyebrow text-navy-300 mb-4">Follow</p>
          <a
            href="https://instagram.com/alykbuilding"
            target="_blank"
            rel="noopener noreferrer"
            class="text-navy-300 inline-flex items-center gap-2 border-0 text-sm no-underline transition-colors hover:text-stone-50"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
              ></path>
            </svg>
            Instagram
          </a>
        </div>
      </div>

      <div
        class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-8 md:flex-row md:items-center"
      >
        <p class="text-navy-500 text-xs">
          &copy; {currentYear} ALYK Building Pty Ltd. All rights reserved.
        </p>
        <p class="text-navy-500 text-xs">Tweed Coast, NSW</p>
      </div>
    </div>
  </Container>
</footer>
