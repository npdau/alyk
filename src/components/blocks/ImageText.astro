---
/**
 * ImageText Block
 *
 * A two-column section with image and text content.
 * Commonly used for about sections, service highlights, etc.
 * Edit the content and styling directly for each project.
 */
import { Image } from 'astro:assets';
import Section from '@/components/core/Section.astro';
import Button from '@/components/core/Button.astro';

interface Props {
  /** Section headline */
  headline: string;
  /** Body text (HTML allowed) */
  body: string;
  /** Image details - for remote images, provide width/height; for local imports, these are inferred */
  image: {
    src: any;
    alt: string;
    width?: number;
    height?: number;
  };
  /** Image position */
  imagePosition?: 'left' | 'right';
  /** Optional CTA button */
  cta?: {
    text: string;
    href: string;
  };
  /** Background variant */
  background?: 'default' | 'muted';
}

const { headline, body, image, imagePosition = 'right', cta, background = 'default' } = Astro.props;
---

<Section spacing="lg" background={background}>
  <div
    class:list={[
      'grid items-center gap-12 lg:grid-cols-2',
      imagePosition === 'left' && 'lg:[&>*:first-child]:order-2',
    ]}
  >
    <div>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        {headline}
      </h2>
      <div class="text-muted-foreground mt-6 space-y-4" set:html={body} />
      {
        cta && (
          <div class="mt-8">
            <Button href={cta.href}>{cta.text}</Button>
          </div>
        )
      }
    </div>
    <div>
      <Image
        src={image.src}
        alt={image.alt}
        width={image.width}
        height={image.height}
        class="rounded-lg shadow-md"
        inferSize={!image.width || !image.height}
      />
    </div>
  </div>
</Section>
