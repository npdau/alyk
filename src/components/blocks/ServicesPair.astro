---
/**
 * ServicesPair Block
 *
 * Two large service cards side by side, each with hero imagery,
 * editorial eyebrow, title, descriptive body, and link through.
 * Used on the services landing page to introduce the two pillars
 * (architectural homes and renovations) with visual weight.
 */
import { Image } from 'astro:assets';
import Section from '@/components/core/Section.astro';

interface ServiceCard {
  eyebrow: string;
  title: string;
  body: string;
  link: { text: string; href: string };
  image: { src: ImageMetadata; alt: string };
}

interface Props {
  /** Optional intro lead-in paragraph above the cards. */
  leadIn?: string;
  services: ServiceCard[];
  background?: 'default' | 'muted';
}

const { leadIn, services, background = 'default' } = Astro.props;
---

<Section spacing="lg" background={background}>
  {
    leadIn && (
      <p
        class="text-foreground mx-auto mb-12 max-w-3xl text-center text-base leading-relaxed sm:text-lg"
        style="line-height: 1.55;"
      >
        {leadIn}
      </p>
    )
  }

  <div class="grid gap-6 md:grid-cols-2 md:gap-8">
    {
      services.map((service) => (
        <div class="service-card group bg-card relative flex flex-col overflow-hidden rounded-lg shadow-md transition-shadow duration-300 hover:shadow-lg">
          <div class="relative aspect-[4/3] overflow-hidden">
            <Image
              src={service.image.src}
              alt={service.image.alt}
              class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
              widths={[400, 600, 800, 1000]}
              sizes="(min-width: 768px) 50vw, 100vw"
              loading="lazy"
              inferSize
            />
          </div>

          <div class="flex flex-1 flex-col p-8 md:p-10">
            <p class="eyebrow mb-3">{service.eyebrow}</p>
            <h3 class="text-foreground text-2xl font-semibold tracking-tight">{service.title}</h3>
            <p
              class="text-muted-foreground mt-4 flex-1 text-base leading-relaxed"
              style="line-height: 1.6;"
            >
              {service.body}
            </p>
            <p class="mt-8">
              <a
                href={service.link.href}
                class="text-foreground hover:border-navy-700 hover:text-navy-700 border-b border-stone-300 text-sm font-medium no-underline transition-colors before:absolute before:inset-0 before:content-['']"
              >
                {service.link.text} &rarr;
              </a>
            </p>
          </div>
        </div>
      ))
    }
  </div>
</Section>
