---
/**
 * ProcessSteps Block
 *
 * Numbered steps in a horizontal/responsive grid.
 */
import Section from '@/components/core/Section.astro';

interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  heading: string;
  leadIn?: string;
  steps: Step[];
}

const { heading, leadIn, steps } = Astro.props;
---

<Section spacing="lg">
  <div class="mb-10">
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      {heading}
    </h2>
    {leadIn && <p class="mt-3 text-base">{leadIn}</p>}
  </div>

  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
    {
      steps.map((step) => (
        <div class="border-border border-t pt-6">
          <p class="eyebrow mb-3">{step.number}</p>
          <h3 class="text-lg font-semibold">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))
    }
  </div>
</Section>
