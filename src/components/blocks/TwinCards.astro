---
/**
 * TwinCards Block
 *
 * Two side-by-side content cards with heading, body, and CTA each.
 */
import Section from '@/components/core/Section.astro';
import Card from '@/components/core/Card.astro';

interface TwinCard {
  heading: string;
  body: string;
  link: { text: string; href: string };
}

interface Props {
  cards: TwinCard[];
  background?: 'default' | 'muted';
}

const { cards, background = 'muted' } = Astro.props;
---

<Section spacing="lg" background={background}>
  <div class="grid gap-6 md:grid-cols-2">
    {
      cards.map((card) => (
        <Card variant="outlined" padding="lg" class="bg-card">
          <h3 class="text-xl font-semibold">{card.heading}</h3>
          <p class="mt-3 text-sm leading-relaxed">{card.body}</p>
          <p class="mt-5">
            <a
              href={card.link.href}
              class="text-foreground hover:border-navy-700 hover:text-navy-700 border-b border-stone-300 text-sm font-medium no-underline transition-colors"
            >
              {card.link.text} &rarr;
            </a>
          </p>
        </Card>
      ))
    }
  </div>
</Section>
