---
/**
 * Accordion Component
 *
 * Expandable/collapsible content sections, perfect for FAQs.
 * Accessible with keyboard navigation and ARIA attributes.
 * Uses only theme tokens - no arbitrary values.
 *
 * @example
 * <Accordion items={[
 *   { id: 'q1', title: 'What is your return policy?', content: 'We offer 30-day returns...' },
 *   { id: 'q2', title: 'How long does shipping take?', content: 'Standard shipping is 3-5 days...' },
 * ]} />
 *
 * <Accordion items={items} type="multiple" defaultOpen={['q1']} />
 */

interface AccordionItem {
  /** Unique identifier */
  id: string;
  /** Title shown in the trigger button */
  title: string;
  /** Content shown when expanded (HTML allowed) */
  content: string;
}

interface Props {
  /** Array of accordion items */
  items: AccordionItem[];
  /** Allow multiple items open at once, or only one */
  type?: 'single' | 'multiple';
  /** IDs of items that should be open by default */
  defaultOpen?: string[];
  /** Visual style variant */
  variant?: 'default' | 'bordered' | 'separated';
  /** HTML id attribute */
  id?: string;
  /** Additional classes */
  class?: string;
}

const {
  items,
  type = 'single',
  defaultOpen = [],
  variant = 'default',
  id,
  class: className,
} = Astro.props;

const accordionId = id || `accordion-${Math.random().toString(36).slice(2, 9)}`;

const containerStyles = {
  default: 'divide-y divide-border',
  bordered: 'divide-y divide-border border border-border rounded-lg overflow-hidden',
  separated: 'space-y-2',
};

const itemStyles = {
  default: '',
  bordered: '',
  separated: 'border border-border rounded-lg overflow-hidden',
};

const triggerStyles = {
  default: 'py-4',
  bordered: 'py-4 px-4',
  separated: 'py-4 px-4',
};

const contentStyles = {
  default: 'pb-4',
  bordered: 'pb-4 px-4',
  separated: 'pb-4 px-4',
};
---

<div
  class:list={[containerStyles[variant], className]}
  id={accordionId}
  data-accordion
  data-accordion-type={type}
>
  {
    items.map((item) => {
      const isOpen = defaultOpen.includes(item.id);
      return (
        <div class={itemStyles[variant]} data-accordion-item data-accordion-item-id={item.id}>
          <h3>
            <button
              type="button"
              class:list={[
                'hover:text-muted-foreground focus-visible:ring-ring flex w-full items-center justify-between text-left font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2',
                triggerStyles[variant],
              ]}
              aria-expanded={isOpen ? 'true' : 'false'}
              aria-controls={`${accordionId}-content-${item.id}`}
              data-accordion-trigger
            >
              <span>{item.title}</span>
              <svg
                class:list={[
                  'h-4 w-4 shrink-0 transition-transform duration-200',
                  isOpen && 'rotate-180',
                ]}
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                data-accordion-icon
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
          </h3>
          <div
            id={`${accordionId}-content-${item.id}`}
            class:list={[
              'overflow-hidden transition-all duration-200',
              isOpen ? 'max-h-96' : 'max-h-0',
            ]}
            data-accordion-content
          >
            <div class:list={['text-muted-foreground text-sm', contentStyles[variant]]}>
              <Fragment set:html={item.content} />
            </div>
          </div>
        </div>
      );
    })
  }
</div>

<script define:vars={{ accordionId }} is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const accordion = document.getElementById(accordionId);
    if (!accordion) return;

    const type = accordion.dataset.accordionType;
    const items = accordion.querySelectorAll('[data-accordion-item]');

    items.forEach((item) => {
      const trigger = item.querySelector('[data-accordion-trigger]');
      const content = item.querySelector('[data-accordion-content]');
      const icon = item.querySelector('[data-accordion-icon]');

      if (!trigger || !content) return;

      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

        // If single mode, close all other items first
        if (type === 'single' && !isExpanded) {
          items.forEach((otherItem) => {
            if (otherItem === item) return;
            const otherTrigger = otherItem.querySelector('[data-accordion-trigger]');
            const otherContent = otherItem.querySelector('[data-accordion-content]');
            const otherIcon = otherItem.querySelector('[data-accordion-icon]');

            if (otherTrigger && otherContent) {
              otherTrigger.setAttribute('aria-expanded', 'false');
              otherContent.classList.remove('max-h-96');
              otherContent.classList.add('max-h-0');
              otherIcon?.classList.remove('rotate-180');
            }
          });
        }

        // Toggle current item
        trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');

        if (isExpanded) {
          content.classList.remove('max-h-96');
          content.classList.add('max-h-0');
          icon?.classList.remove('rotate-180');
        } else {
          content.classList.remove('max-h-0');
          content.classList.add('max-h-96');
          icon?.classList.add('rotate-180');
        }
      });
    });

    // Keyboard navigation
    accordion.addEventListener('keydown', (e) => {
      const target = e.target;
      if (!target.hasAttribute('data-accordion-trigger')) return;

      const triggers = Array.from(accordion.querySelectorAll('[data-accordion-trigger]'));
      const currentIndex = triggers.indexOf(target);

      let newIndex;
      switch (e.key) {
        case 'ArrowDown':
          newIndex = currentIndex === triggers.length - 1 ? 0 : currentIndex + 1;
          break;
        case 'ArrowUp':
          newIndex = currentIndex === 0 ? triggers.length - 1 : currentIndex - 1;
          break;
        case 'Home':
          newIndex = 0;
          break;
        case 'End':
          newIndex = triggers.length - 1;
          break;
        default:
          return;
      }

      e.preventDefault();
      triggers[newIndex].focus();
    });
  });
</script>
