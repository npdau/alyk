---
/**
 * Avatar Component
 *
 * A circular image for user/team member photos.
 * Shows initials as fallback when no image is provided.
 * Uses only theme tokens - no arbitrary values.
 *
 * @example
 * <Avatar src="/team/jane.jpg" alt="Jane Doe" />
 * <Avatar src="/team/john.jpg" alt="John Smith" size="lg" />
 * <Avatar alt="Bob Wilson" fallback="BW" />
 */
import { Image } from 'astro:assets';

interface Props {
  /** Image source URL or imported image */
  src?: any;
  /** Alt text for the image */
  alt: string;
  /** Fallback initials (auto-generated from alt if not provided) */
  fallback?: string;
  /** Size variant */
  size?: 'sm' | 'md' | 'lg' | 'xl';
  /** Width for remote images (optional for local imports) */
  width?: number;
  /** Height for remote images (optional for local imports) */
  height?: number;
  /** Additional classes */
  class?: string;
}

const { src, alt, fallback, size = 'md', width, height, class: className } = Astro.props;

// Generate initials from alt text if no fallback provided
const initials =
  fallback ||
  alt
    .split(' ')
    .map((word) => word[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);

const sizeStyles = {
  sm: 'h-8 w-8 text-xs',
  md: 'h-10 w-10 text-sm',
  lg: 'h-12 w-12 text-base',
  xl: 'h-16 w-16 text-lg',
};
---

<div
  class:list={[
    'bg-muted relative flex shrink-0 items-center justify-center overflow-hidden rounded-full',
    sizeStyles[size],
    className,
  ]}
>
  {
    src ? (
      <Image
        src={src}
        alt={alt}
        width={width}
        height={height}
        class="aspect-square h-full w-full object-cover"
        inferSize={typeof src !== 'string'}
      />
    ) : (
      <span class="text-muted-foreground font-medium">{initials}</span>
    )
  }
</div>
