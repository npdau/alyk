---
/**
 * PageLayout
 *
 * Standard page layout with TopNav and Footer.
 * Use this for all public-facing pages.
 *
 * Props flow through to BaseLayout for SEO handling.
 */
import BaseLayout from './BaseLayout.astro';
import TopNav from '@/components/blocks/TopNav.astro';
import Footer from '@/components/blocks/Footer.astro';
import Container from '@/components/core/Container.astro';

type SchemaObject = Record<string, unknown>;

interface Props {
  /** Page title (required for SEO) */
  title: string;
  /** Meta description */
  description?: string;
  /** Open Graph image */
  image?: string;
  /** Page type for Open Graph */
  type?: 'website' | 'article';
  /** Hide from search engines */
  noIndex?: boolean;
  /** Page-specific schema.org JSON-LD (breadcrumbs, services, etc.) */
  schema?: SchemaObject | SchemaObject[];
  /** Full-width layout (no container padding) */
  fullWidth?: boolean;
  /** Transparent header over hero imagery */
  transparentNav?: boolean;
}

const { fullWidth = false, transparentNav = false, ...layoutProps } = Astro.props;
---

<BaseLayout {...layoutProps}>
  <slot name="head" slot="head" />

  <div class="flex min-h-screen flex-col">
    <TopNav transparent={transparentNav} />

    <main id="main-content" class="flex-1">
      {
        fullWidth ? (
          <slot />
        ) : (
          <Container class="py-8">
            <slot />
          </Container>
        )
      }
    </main>

    <Footer />
  </div>

  <slot name="scripts" slot="scripts" />
</BaseLayout>
