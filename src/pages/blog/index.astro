---
/**
 * Blog Index Page
 *
 * Lists all published blog posts.
 * Rename this folder to match your content type (guides, articles, news, etc.)
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Card from '@/components/core/Card.astro';
import Badge from '@/components/core/Badge.astro';
import { formatDate } from '@/lib/utils';

// Get all non-draft posts, sorted by date (newest first)
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout title="Blog" description="Latest articles, guides, and updates from our team.">
  <div class="mb-12">
    <h1 class="text-4xl font-bold">Blog</h1>
    <p class="text-muted-foreground mt-4 text-lg">
      Latest articles, guides, and updates from our team.
    </p>
  </div>

  {
    posts.length === 0 ? (
      <Card class="p-8 text-center">
        <p class="text-muted-foreground">No posts yet. Check back soon!</p>
      </Card>
    ) : (
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group block no-underline">
            <Card class="h-full transition-shadow hover:shadow-md">
              {post.data.image && (
                <Image
                  src={post.data.image}
                  alt=""
                  width={600}
                  height={338}
                  class="mb-4 aspect-video w-full rounded-md object-cover"
                />
              )}
              <div class="space-y-3">
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <Badge variant="secondary">{tag}</Badge>
                    ))}
                  </div>
                )}
                <h2 class="group-hover:text-primary text-xl font-semibold transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-muted-foreground line-clamp-2">{post.data.description}</p>
                <p class="text-muted-foreground text-sm">{formatDate(post.data.pubDate)}</p>
              </div>
            </Card>
          </a>
        ))}
      </div>
    )
  }
</PageLayout>
