---
/**
 * Blog Post Page
 *
 * Dynamic route for individual blog posts.
 * Rename this folder to match your content type (guides, articles, news, etc.)
 *
 * Note: The post title becomes the h1, so markdown content should NOT include
 * its own h1 heading. Start content with h2 (##) or below.
 */
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Breadcrumbs from '@/components/core/Breadcrumbs.astro';
import Badge from '@/components/core/Badge.astro';
import { formatDate } from '@/lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<PageLayout title={post.data.title} description={post.data.description} type="article">
  <article class="mx-auto max-w-3xl">
    <!-- Header -->
    <header class="mb-8">
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="mb-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <Badge variant="secondary">{tag}</Badge>
            ))}
          </div>
        )
      }
      <h1 class="text-4xl font-bold md:text-5xl">{post.data.title}</h1>
      <p class="text-muted-foreground mt-4 text-lg">
        {post.data.description}
      </p>
      <div class="text-muted-foreground mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
        <span>By {post.data.author}</span>
        <span>·</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        {
          post.data.updatedDate && (
            <>
              <span>·</span>
              <span>Updated {formatDate(post.data.updatedDate)}</span>
            </>
          )
        }
      </div>
    </header>

    <!-- Featured Image -->
    {
      post.data.image && (
        <Image
          src={post.data.image}
          alt=""
          width={1200}
          height={675}
          class="mb-8 aspect-video w-full rounded-lg object-cover"
        />
      )
    }

    <!-- Breadcrumbs -->
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Blog', href: '/blog' },
        { label: post.data.title },
      ]}
      class="mb-8"
    />

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>
  </article>
</PageLayout>
