---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroHome from '@/components/blocks/HeroHome.astro';
import ProjectInfo from '@/components/blocks/ProjectInfo.astro';
import ProjectGallery from '@/components/blocks/ProjectGallery.astro';
import ProjectNav from '@/components/blocks/ProjectNav.astro';

import heroImage from '@/assets/images/projects/casuarina-i-renovation/casuarina-i-renovation-01.webp';

const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/projects/casuarina-i-renovation/*.webp',
  { eager: true }
);
const galleryImages = Object.keys(galleryModules)
  .sort()
  .slice(1)
  .map((key) => galleryModules[key].default);
---

<PageLayout
  title="Casuarina Renovation | ALYK Building"
  description="A three-storey renovation at Casuarina by Create Architecture, doubling the original floor area and adding a new level above the existing footprint."
  fullWidth
  transparentNav
>
  <HeroHome
    height="short"
    image={{
      src: heroImage,
      alt: 'Casuarina renovation by ALYK Building',
    }}
  />

  <ProjectInfo
    title="Casuarina"
    subtitle="A three-storey renovation by Create Architecture."
    description={[
      'A full-scale renovation at Casuarina, drawn by Create Architecture. The existing home was taken back to its footprint and rebuilt across three storeys, with a new top level added to bring the home up to the light and the wider view. The reworked plan doubles the floor area of the original while keeping its position on the block.',
      'Inside, the finishes are anchored in natural stone: Patagonia Quartzite in the kitchen, a feature wall in the bathroom, and travertine through the floors. Shou Sugi Ban cladding wraps the exterior in a deep, textured black, and a floating stair runs the full three storeys.',
    ]}
    details={[
      { label: 'Location', value: 'Casuarina, Northern NSW' },
      { label: 'Builder', value: 'ALYK Building' },
      { label: 'Architect', value: 'Create Architecture' },
      { label: 'Photography', value: 'Andy Macpherson, AM Studio' },
    ]}
  />

  <ProjectGallery images={galleryImages} alt="Casuarina renovation by ALYK Building" />

  <ProjectNav nextProject={{ title: 'Cabarita Beach', href: '/projects/cabarita-beach/' }} />
</PageLayout>
