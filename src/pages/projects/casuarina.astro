---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroHome from '@/components/blocks/HeroHome.astro';
import ProjectInfo from '@/components/blocks/ProjectInfo.astro';
import ProjectGallery from '@/components/blocks/ProjectGallery.astro';
import ProjectNav from '@/components/blocks/ProjectNav.astro';

import heroImage from '@/assets/images/projects/casuarina-i-build/casuarina-i-build-01.webp';
import { getBreadcrumbSchema } from '@/lib/schema';

const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/projects/casuarina-i-build/*.webp',
  { eager: true }
);
const galleryImages = Object.keys(galleryModules)
  .sort()
  .slice(1)
  .map((key) => galleryModules[key].default);

const breadcrumb = getBreadcrumbSchema(Astro.site!, [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects/' },
  { label: 'Casuarina' },
]);
---

<PageLayout
  title="Casuarina - New Build | ALYK Building"
  description="A custom family home at Casuarina designed by Jordan Pope at Impact Design - opening its main living spaces straight onto the deck and pool."
  schema={breadcrumb}
  fullWidth
  transparentNav
>
  <HeroHome
    height="short"
    image={{
      src: heroImage,
      alt: 'Casuarina new build by ALYK Building',
    }}
  />

  <ProjectInfo
    title="Casuarina"
    subtitle="A relaxed coastal home for family life and entertaining."
    description={[
      'Designed for relaxed coastal living, this custom family home at Casuarina opens its main living spaces straight onto the deck and pool. The exterior is finished in Linearboard cladding, with full-height sliding glazing across the main level and a frameless corner sliding door at the corner of the living zone.',
      "Inside, blind pelmets carry through the home for a clean ceiling line, and the upper level steps back to take in the wider coastal outlook. It's a warm, family-focused home for everyday living and entertaining.",
    ]}
    details={[
      { label: 'Location', value: 'Casuarina, Northern NSW' },
      { label: 'Type', value: 'New Build' },
      { label: 'Builder', value: 'ALYK Building' },
      { label: 'Architect', value: 'Jordan Pope, Impact Design' },
      { label: 'Photography', value: 'Andy Macpherson, AM Studio' },
    ]}
  />

  <ProjectGallery images={galleryImages} alt="Casuarina new build by ALYK Building" />

  <ProjectNav nextProject={{ title: 'Casuarina Renovation', href: '/projects/casuarina-reno/' }} />
</PageLayout>
