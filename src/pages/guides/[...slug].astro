---
/**
 * Guide Page
 *
 * Dynamic route for individual guides.
 *
 * Note: The guide title becomes the h1, so markdown content should NOT include
 * its own h1 heading. Start content with h2 (##) or below.
 */
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Breadcrumbs from '@/components/core/Breadcrumbs.astro';
import Badge from '@/components/core/Badge.astro';
import { formatDate } from '@/lib/utils';
import { getBreadcrumbSchema } from '@/lib/schema';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);

const breadcrumb = getBreadcrumbSchema(Astro.site!, [
  { label: 'Home', href: '/' },
  { label: 'Guides', href: '/guides/' },
  { label: guide.data.title },
]);
---

<PageLayout
  title={guide.data.title}
  description={guide.data.description}
  type="article"
  schema={breadcrumb}
>
  <article class="mx-auto max-w-3xl">
    <!-- Header -->
    <header class="mb-8">
      {
        guide.data.tags && guide.data.tags.length > 0 && (
          <div class="mb-4 flex flex-wrap gap-2">
            {guide.data.tags.map((tag) => (
              <Badge variant="secondary">{tag}</Badge>
            ))}
          </div>
        )
      }
      <h1 class="text-4xl font-bold md:text-5xl">{guide.data.title}</h1>
      <p class="text-muted-foreground mt-4 text-lg">
        {guide.data.description}
      </p>
      <div class="text-muted-foreground mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
        <span>By {guide.data.author}</span>
        <span>·</span>
        <time datetime={guide.data.pubDate.toISOString()}>
          {formatDate(guide.data.pubDate)}
        </time>
        {
          guide.data.updatedDate && (
            <>
              <span>·</span>
              <span>Updated {formatDate(guide.data.updatedDate)}</span>
            </>
          )
        }
      </div>
    </header>

    <!-- Featured Image -->
    {
      guide.data.image && (
        <Image
          src={guide.data.image}
          alt=""
          width={1200}
          height={675}
          class="mb-8 aspect-video w-full rounded-lg object-cover"
        />
      )
    }

    <!-- Breadcrumbs -->
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Guides', href: '/guides/' },
        { label: guide.data.title },
      ]}
      class="mb-8"
    />

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>
  </article>
</PageLayout>
