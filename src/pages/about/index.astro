---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroHome from '@/components/blocks/HeroHome.astro';
import AboutSummary from '@/components/blocks/AboutSummary.astro';
import IntroBlock from '@/components/blocks/IntroBlock.astro';
import TestimonialsGrid from '@/components/blocks/TestimonialsGrid.astro';
import PlaceStatement from '@/components/blocks/PlaceStatement.astro';
import Accreditations from '@/components/blocks/Accreditations.astro';
import ConsultationCTA from '@/components/blocks/ConsultationCTA.astro';
import heroImage from '@/assets/images/projects/cabarita-beach-i-build/cabarita-beach-i-build-29.webp';
import aboutPhoto from '@/assets/images/team/aaron-and-yarran.webp';
import coastalPhoto from '@/assets/images/scenic/coastal-caba-1.webp';
import logoFairTrade from '@/assets/images/memberships/fair-trade-mono.webp';
import logoMasterBuilder from '@/assets/images/memberships/master-builder.webp';
import logoInsurance from '@/assets/images/memberships/insurance-mono.webp';
---

<PageLayout
  title="About ALYK Building - Architectural Builders, Tweed Coast"
  description="Aaron Lee and Yarran Kerr are two Tweed Coast locals running a custom building practice on the stretch of coast they know best - architectural homes and renovations from Fingal Head to New Brighton."
  fullWidth
  transparentNav
>
  <HeroHome
    headline="Built to belong on the Tweed Coast"
    subheadline="Aaron Lee and Yarran Kerr, two Tweed Coast locals running a custom building practice on the stretch of coast they know best."
    image={{
      src: heroImage,
      alt: 'Architectural home built by ALYK Building on the Tweed Coast',
    }}
  />

  <AboutSummary
    eyebrow="The story"
    heading="From this coast, for this coast"
    body={[
      'Aaron Lee and Yarran Kerr both grew up on the Tweed Coast. They started out as apprentices under an award-winning local builder, and have been working on this stretch of coastline ever since. They started ALYK Building to do the work they care about most: architecturally drawn homes, built carefully, on a coast they know in detail.',
      "We build for the place we live in. We don't take work outside it, and we don't take more of it than we can run well.",
    ]}
    image={{ src: aboutPhoto, alt: 'Aaron Lee and Yarran Kerr, founders of ALYK Building' }}
  />

  <IntroBlock
    eyebrow="How we work"
    heading="Architectural homes, built with care"
    background="default"
    maxWidth="md"
    body={[
      'We build architectural homes and major renovations on the Tweed Coast, working alongside your architect from drawing through to handover. Early input on buildability, materials and schedule is available where it helps lock the design.',
      "We run every build to a proven framework for project management and budgeting: schedule tracked, costs itemised and reported, variations written and signed before they're done. With a small project load and Aaron or Yarran on every site, that framework stays close to the work. The standard depends on it.",
    ]}
  />

  <TestimonialsGrid
    eyebrow="Client Feedback"
    heading="Built on trust, backed by results"
    background="muted"
    testimonials={[
      {
        quote:
          'We chose ALYK to build our home as we have known Aaron and Yarran since they were young and they did their apprenticeships with an award-winning builder, known to us. The quality of their workmanship is exceptional, and they were very open to listening to our ideas and provided us with great input. They were very easy to communicate with and helped us to build the home we envisaged. We are very happy with the award-winning home they have built for us.',
        name: 'Ellis & Rosemary',
        location: 'Bogangar',
        projectHref: '/projects/cabarita-beach/',
      },
      {
        quote:
          'Working with ALYK Builders has been an outstanding experience from start to finish. We chose ALYK because of the strong local reputation and values Aaron and Yaran built early in their careers, and throughout the entire process they more than lived up to that trust. Their attention to detail are exceptional, but what really stood out was the way they genuinely listened. They took the time to understand our vision, offered thoughtful ideas and practical guidance, and made us feel supported and involved at every stage of the build. Communication was always open, honest and responsive, which gave us a great deal of confidence throughout the project. Building a home can be stressful, but Aaron and Yaran approached everything with professionalism, care and pride in their work. The end result is a beautiful build that exceeded our expectations and reflects the quality ALYK is known for. We are incredibly grateful for the experience and would highly recommend ALYK Builders to anyone looking for a builder who combines high-quality build quality with genuine customer care.',
        name: 'Kollen & Hayley',
        location: 'Cabarita Beach',
        projectHref: '/projects/cabarita-beach-2/',
      },
      {
        quote: 'Client quote coming soon.',
        name: 'Client name',
        location: 'Suburb',
        placeholder: true,
      },
    ]}
  />

  <PlaceStatement
    eyebrow="Where we work"
    place="Fingal Head to New Brighton"
    description={[
      'The Tweed Coast, Fingal Head, Kingscliff, Casuarina, Cabarita Beach, Hastings Point, Pottsville, Wooyung, New Brighton.',
      'Building only on this stretch means a few things in practice. We know how the coast behaves, salt, wind, sun, sand, and we build for it. The supplier and trade relationships we rely on are ones we\u2019ve built up over years on local jobs. And the work we do stays in the community we\u2019re part of.',
      "We don't build outside this stretch, and we don't run remote project management. Aaron or Yarran is on every site we run.",
    ]}
    image={{
      src: coastalPhoto,
      alt: 'Coastal view of Cabarita Beach on the Tweed Coast',
    }}
  />

  <Accreditations
    items={[
      { label: 'NSW LIC #374055C', logo: { src: logoFairTrade, alt: 'NSW Fair Trading logo' } },
      {
        label: 'Member of',
        logo: { src: logoMasterBuilder, alt: 'Master Builders Association logo' },
      },
      {
        label: 'Insured by',
        logo: { src: logoInsurance, alt: 'Master Builders Insurance Brokers logo' },
      },
    ]}
  />

  <ConsultationCTA
    heading="The first step towards your dream home"
    cta={{ text: 'Begin a project', href: '/contact/' }}
    background="default"
  />
</PageLayout>
