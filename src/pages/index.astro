---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroHome from '@/components/blocks/HeroHome.astro';
import IntroBlock from '@/components/blocks/IntroBlock.astro';
import ServicesSnapshot from '@/components/blocks/ServicesSnapshot.astro';
import ProjectShowcase from '@/components/blocks/ProjectShowcase.astro';
import Testimonial from '@/components/blocks/Testimonial.astro';
import ConsultationCTA from '@/components/blocks/ConsultationCTA.astro';

import heroImage from '@/assets/images/projects/cabarita beach i - build/cabarita beach i - build - 01.webp';
import projectCabaritaI from '@/assets/images/projects/cabarita beach i - build/cabarita beach i - build - 05.webp';
import projectCabaritaII from '@/assets/images/projects/cabarita beach ii - build/cabarita beach ii - build - 01.webp';
import projectCasuarinaBuild from '@/assets/images/projects/casuarina i - build/casuarina i - build - 01.webp';
import projectCasuarinaReno from '@/assets/images/projects/casuarina i - renovation/casuarina i - renovation - 01.webp';
---

<PageLayout
  title="ALYK Building — Architectural Homes & Renovations, Tweed Coast"
  description="ALYK Building specialise in architectural homes and renovations between Fingal Head and New Brighton — built in close collaboration with the architects who design them."
  fullWidth
  transparentNav
>
  <HeroHome
    headline="Architectural homes on the Tweed Coast."
    subheadline="ALYK Building specialise in architectural homes and renovations between Fingal Head and New Brighton — built in close collaboration with the architects who design them."
    cta={{ text: 'Begin a project', href: '/contact/' }}
    image={{ src: heroImage, alt: 'Architectural home by ALYK Building on the Tweed Coast' }}
  />

  <IntroBlock
    heading="Built for the place we live in."
    body="ALYK Building specialises in architectural homes and major renovations between Fingal Head and New Brighton. We work to architects' drawings, with buildability input as early as it helps. We don't build outside the Tweed Coast, and we don't take on more work than we can run well."
  />

  <ServicesSnapshot
    services={[
      {
        title: 'Architectural homes',
        description:
          "New custom builds on coastal sites. We work to your architect's drawings, with buildability input as early as it's useful.",
        link: { text: 'More on new builds', href: '/services/builds/' },
      },
      {
        title: 'Renovations',
        description:
          'Major renovations and extensions on existing homes. The same standard, same care, same architectural-grade detail as a new build.',
        link: { text: 'More on renovations', href: '/services/renovations/' },
      },
    ]}
  />

  <ProjectShowcase
    heading="Recent work."
    description="A selection of homes we've built and renovated on the Tweed Coast. Each project page includes the brief, the site, the architect, and a full gallery."
    projects={[
      {
        title: 'Cabarita Beach',
        tag: 'NEW BUILD',
        image: { src: projectCabaritaI, alt: 'Cabarita Beach new build by ALYK Building' },
        href: '/projects/cabarita-beach/',
      },
      {
        title: 'Casuarina',
        tag: 'NEW BUILD',
        image: { src: projectCasuarinaBuild, alt: 'Casuarina new build by ALYK Building' },
        href: '/projects/casuarina/',
      },
      {
        title: 'Cabarita Beach II',
        tag: 'NEW BUILD',
        image: { src: projectCabaritaII, alt: 'Cabarita Beach II new build by ALYK Building' },
        href: '/projects/cabarita-beach-2/',
      },
      {
        title: 'Casuarina',
        tag: 'RENOVATION',
        image: { src: projectCasuarinaReno, alt: 'Casuarina renovation by ALYK Building' },
        href: '/projects/casuarina-renovation/',
      },
    ]}
    cta={{ text: 'View all projects', href: '/projects/' }}
  />

  <IntroBlock
    heading="Aaron Lee and Yarran Kerr — Tweed locals."
    body="ALYK is the work of Aaron Lee and Yarran Kerr — two locals running a custom building practice on the strip of coast they grew up on. The two of them are on every site we run."
    link={{ text: 'More about ALYK', href: '/about/' }}
  />

  <Testimonial
    quote="We chose ALYK to build our home as we have known Aaron and Yarran since they were young and they did their apprenticeships with an award-winning builder, known to us. The quality of their workmanship is exceptional, and they were very open to listening to our ideas and provided us with great input. They were very easy to communicate with and helped us to build the home we envisaged. We are very happy with the award-winning home they have built for us."
    name="Ellis & Rosemary"
    location="Bogangar"
    background="muted"
  />

  <ConsultationCTA
    heading="Schedule a free consultation."
    body="Send us a brief — even a thumbnail of what you've drawn, the site, and a rough programme. We'll come back to you within a couple of business days, and we'll be honest about whether the project's a fit."
    cta={{ text: 'Begin an enquiry', href: '/contact/' }}
  />
</PageLayout>
