---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroHome from '@/components/blocks/HeroHome.astro';
import ServicesPair from '@/components/blocks/ServicesPair.astro';
import AboutSummary from '@/components/blocks/AboutSummary.astro';
import ProjectShowcase from '@/components/blocks/ProjectShowcase.astro';
import TestimonialsGrid from '@/components/blocks/TestimonialsGrid.astro';
import ConsultationCTA from '@/components/blocks/ConsultationCTA.astro';

import heroImage from '@/assets/images/projects/cabarita-beach-ii-build/cabarita-beach-ii-build-01.webp';

import buildsImage from '@/assets/images/projects/cabarita-beach-i-build/cabarita-beach-i-build-26.webp';
import renovationsImage from '@/assets/images/projects/casuarina-i-renovation/casuarina-i-renovation-16.webp';

import cabII04 from '@/assets/images/projects/cabarita-beach-ii-build/cabarita-beach-ii-build-04.webp';
import cabII05 from '@/assets/images/projects/cabarita-beach-ii-build/cabarita-beach-ii-build-07.webp';
import cabII11 from '@/assets/images/projects/cabarita-beach-ii-build/cabarita-beach-ii-build-11.webp';
import cabII17 from '@/assets/images/projects/cabarita-beach-ii-build/cabarita-beach-ii-build-17.webp';
import cabII34 from '@/assets/images/projects/cabarita-beach-ii-build/cabarita-beach-ii-build-33.webp';
import cabII44 from '@/assets/images/projects/cabarita-beach-ii-build/cabarita-beach-ii-build-44.webp';

import casReno01 from '@/assets/images/projects/casuarina-i-renovation/casuarina-i-renovation-01.webp';
import casReno12 from '@/assets/images/projects/casuarina-i-renovation/casuarina-i-renovation-12.webp';
import casReno14 from '@/assets/images/projects/casuarina-i-renovation/casuarina-i-renovation-14.webp';
import casReno16 from '@/assets/images/projects/casuarina-i-renovation/casuarina-i-renovation-16.webp';
import casReno20 from '@/assets/images/projects/casuarina-i-renovation/casuarina-i-renovation-20.webp';
import casReno22 from '@/assets/images/projects/casuarina-i-renovation/casuarina-i-renovation-22.webp';

import aboutPhoto from '@/assets/images/team/aaron-and-yarran.webp';
---

<PageLayout
  title="ALYK Building - Architectural Homes & Renovations, Tweed Coast"
  description="ALYK Building specialise in architectural homes and renovations between Fingal Head and New Brighton - built in close collaboration with the architects who design them."
  fullWidth
  transparentNav
>
  <HeroHome
    headline="Architectural homes on the Tweed Coast"
    subheadline="ALYK Building specialise in architectural homes and renovations between Fingal Head and New Brighton - built in close collaboration with the architects who design them."
    cta={{ text: 'Begin a project', href: '/contact/' }}
    image={{ src: heroImage, alt: 'Architectural home by ALYK Building on the Tweed Coast' }}
  />

  <ServicesPair
    background="default"
    services={[
      {
        eyebrow: 'New builds',
        title: 'Architectural homes',
        body: 'Custom builds on coastal sites, working closely with your architect from initial detailing through to handover. Aaron and Yarran lead every build, keeping the work on site true to the drawings.',
        link: { text: 'More on new builds', href: '/services/builds/' },
        image: {
          src: buildsImage,
          alt: 'Architectural new build by ALYK Building at Cabarita Beach',
        },
      },
      {
        eyebrow: 'Renovations',
        title: 'Renovations and extensions',
        body: 'Major architectural renovations and extensions on existing homes. The same detail, finish and care as a new build, applied to a home that already has a story.',
        link: { text: 'More on renovations', href: '/services/renovations/' },
        image: {
          src: renovationsImage,
          alt: 'Architectural renovation by ALYK Building at Casuarina',
        },
      },
    ]}
  />

  <AboutSummary
    heading="Aaron Lee and Yarran Kerr, Tweed locals"
    body="ALYK is the work of Aaron Lee and Yarran Kerr - two locals running a custom building practice on the strip of coast they grew up on. We build every home as if it's our own, choosing the right path - not the easy one."
    image={{ src: aboutPhoto, alt: 'Aaron Lee and Yarran Kerr, founders of ALYK Building' }}
    stats={[
      {
        value: '10+',
        label: 'Years Experience',
        description: 'Over a decade building architectural homes on the Tweed Coast.',
      },
      {
        value: 'A+',
        label: 'High Quality Builds',
        description: 'Custom builds and major renovations delivered to architect-grade standards.',
      },
      {
        value: '100%',
        label: 'Owner Operated',
        description: 'Aaron and Yarran are on every site, no project managers, no hand-offs.',
      },
    ]}
    link={{ text: 'More about ALYK', href: '/about/' }}
  />

  <ProjectShowcase
    heading="Recent work"
    description="A selection of homes we've built and renovated on the Tweed Coast. Each project page includes the brief, the site, the architect, and a full gallery."
    projects={[
      {
        title: 'Cabarita Beach II',
        tag: 'NEW BUILD',
        images: [
          { src: cabII04, alt: 'Cabarita Beach II exterior with pool' },
          { src: cabII05, alt: 'Cabarita Beach II front facade at dusk' },
          { src: cabII11, alt: 'Cabarita Beach II front facade' },
          { src: cabII17, alt: 'Cabarita Beach II arched windows and lounge' },
          { src: cabII34, alt: 'Cabarita Beach II staircase' },
          { src: cabII44, alt: 'Cabarita Beach II kitchen and living' },
        ],
        href: '/projects/cabarita-beach-2/',
      },
      {
        title: 'Casuarina',
        tag: 'RENOVATION',
        images: [
          { src: casReno01, alt: 'Casuarina renovation exterior with palms' },
          { src: casReno16, alt: 'Casuarina renovation exterior side angle' },
          { src: casReno20, alt: 'Casuarina renovation exterior at dusk' },
          { src: casReno12, alt: 'Casuarina renovation kitchen' },
          { src: casReno14, alt: 'Casuarina renovation living area' },
          { src: casReno22, alt: 'Casuarina renovation dining at night' },
        ],
        href: '/projects/casuarina-reno/',
      },
    ]}
    cta={{ text: 'View all projects', href: '/projects/' }}
  />

  <TestimonialsGrid
    eyebrow="Client Feedback"
    heading="Built on trust, backed by results"
    background="muted"
    testimonials={[
      {
        quote:
          'We chose ALYK to build our home as we have known Aaron and Yarran since they were young and they did their apprenticeships with an award-winning builder, known to us. The quality of their workmanship is exceptional, and they were very open to listening to our ideas and provided us with great input. They were very easy to communicate with and helped us to build the home we envisaged. We are very happy with the award-winning home they have built for us.',
        name: 'Ellis & Rosemary',
        location: 'Bogangar',
        projectHref: '/projects/cabarita-beach/',
      },
      {
        quote:
          'Working with ALYK Builders has been an outstanding experience from start to finish. We chose ALYK because of the strong local reputation and values Aaron and Yaran built early in their careers, and throughout the entire process they more than lived up to that trust. Their attention to detail are exceptional, but what really stood out was the way they genuinely listened. They took the time to understand our vision, offered thoughtful ideas and practical guidance, and made us feel supported and involved at every stage of the build. Communication was always open, honest and responsive, which gave us a great deal of confidence throughout the project. Building a home can be stressful, but Aaron and Yaran approached everything with professionalism, care and pride in their work. The end result is a beautiful build that exceeded our expectations and reflects the quality ALYK is known for. We are incredibly grateful for the experience and would highly recommend ALYK Builders to anyone looking for a builder who combines high-quality build quality with genuine customer care.',
        name: 'Kollen & Hayley',
        location: 'Cabarita Beach',
        projectHref: '/projects/cabarita-beach-2/',
      },
      {
        quote: 'Client quote coming soon.',
        name: 'Client name',
        location: 'Suburb',
        placeholder: true,
      },
    ]}
  />

  <ConsultationCTA
    heading="Schedule a free consultation."
    body="Send us a brief - even a thumbnail of what you've drawn, the site, and a rough programme. We'll come back to you within a couple of business days, and we'll be honest about whether the project's a fit."
    cta={{ text: 'Begin an enquiry', href: '/contact/' }}
  />
</PageLayout>
